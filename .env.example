# Wigolo search service — copy to .env and adjust

# SearXNG instance for additional search engine coverage
# Points at our existing SearXNG running via web_search_service compose (port 8588)
SEARXNG_URL=http://172.17.0.1:8588

# LLM for research/answer synthesis (optional — search/fetch/crawl work keyless)
WIGOLO_LLM_PROVIDER=openai
OPENAI_BASE_URL=http://172.17.0.1:8081/v1
OPENAI_API_KEY=mclab-llm-key

# Token for external access (leave unset for LAN-only open access)
# WIGOLO_API_TOKEN=change-me-to-a-long-random-secret
